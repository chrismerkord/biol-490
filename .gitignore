# ============================================================
# RStudio / R session artifacts
# ------------------------------------------------------------
# Files generated by RStudio or the R session environment.
# These contain editor state or workspace data and should
# never be version-controlled because they are user-specific
# and frequently change.
# ============================================================

.Rproj.user
.Rhistory
.RData
.Ruserdata

# ============================================================
# Quarto rendered output
# ------------------------------------------------------------
# The rendered website produced by `quarto render`.
# This directory is rebuilt automatically during rendering
# and during GitHub Actions deployment, so it should not be
# stored in the repository.
# ============================================================

/_site/

# ============================================================
# Quarto build metadata and execution artifacts
# ------------------------------------------------------------
# Files created during Quarto rendering that represent build
# state or execution intermediates. These are regenerated
# automatically and should not be tracked in git.
# ============================================================

# internal Quarto build state used during rendering
/.quarto/
# intermediate notebooks created when executing documents
**/*.quarto_ipynb

# ============================================================
# Computational execution caches
# ------------------------------------------------------------
# knitr chunk caches created when `execute.cache: true` is
# enabled in `_quarto.yml`. Quarto places these caches in
# document-specific directories (e.g., `index_cache/`) next to
# each rendered document. They contain serialized R objects
# and intermediate results used to speed up local rendering.
#
# These caches are machine-specific and can be safely rebuilt,
# so they should never be committed to the repository.
#
# NOTE: Do NOT ignore `_freeze/`. That directory stores frozen
# execution results used by `execute.freeze: auto`, which must
# remain tracked so CI builds can skip re-running code.
# ============================================================

# Rendered document support folders created during local Quarto renders
**/index_files/
# knitr execution caches
**/*_cache/